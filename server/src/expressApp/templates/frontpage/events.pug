- const moment = events.moment
div.events
	h2 Kommende hendelser
	ul.list-unstyled
		for event in events.events
			li.list-item.card.card-body
				a(href=event.link target="_blank")
					h3.card-title= event.name
				time(datetime=moment(event.time).toISOString())= moment(event.time).format("Do MMM HH:mm")
