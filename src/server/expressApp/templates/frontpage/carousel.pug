div#carousel.col-12.carousel.slide(data-ride="carousel")
	ol.carousel-indicators
		each _, i in carousel.imageUrls
			li(class=(i === 0 ? "active" : null) data-slide-to=i data-target="#carousel")
	div.carousel-inner
		each image, i in carousel.imageUrls
			div.carousel-item(class=(i === 0 ? "active" : null))
				img.w-100(src=image alt="")
	a.carousel-control-prev(href="#carousel" role="button" data-slide="prev")
		span.carousel-control-prev-icon(aria-hidden="true")
		span.sr-only Previous
	a.carousel-control-next(href="#carousel" role="button" data-slide="next")
		span.carousel-control-next-icon(aria-hidden="true")
		span.sr-only Next
